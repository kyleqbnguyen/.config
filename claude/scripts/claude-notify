#!/usr/bin/env bash
terminal_class="com.mitchellh.ghostty"

event="${1:-Notification}"

payload=""
if [[ ! -t 0 ]]; then
    payload=$(cat)
fi

case "$event" in
    Stop) body="Finished" ;;
    *)
        msg=$(jq -r '.message // empty' <<<"$payload" 2>/dev/null)
        if [[ "$msg" == *"waiting for your input"* ]]; then
            exit 0
        fi
        body="${msg:-Needs your attention}"
        ;;
esac

session_id=""
session_name=""
window_id=""

is_focused() {
    [[ -z "$TMUX_PANE" ]] && return 1
    local pa wa sa _sid _sname _wid
    read -r pa wa sa _sid _sname _wid < <(
        tmux display-message -p -t "$TMUX_PANE" \
            -F '#{pane_active} #{window_active} #{session_attached} #{session_id} #{session_name} #{window_id}' 2>/dev/null
    )
    [[ "$pa" == 1 && "$wa" == 1 && "${sa:-0}" -gt 0 ]] || return 1
    if command -v hyprctl >/dev/null 2>&1; then
        local ac
        ac=$(hyprctl activewindow -j 2>/dev/null | jq -r '.class // empty')
        [[ "$ac" == "$terminal_class" ]] || return 1
    fi
    return 0
}

if [[ -n "$TMUX_PANE" ]]; then
    read -r _ _ _ session_id session_name window_id < <(
        tmux display-message -p -t "$TMUX_PANE" \
            -F '#{pane_active} #{window_active} #{session_attached} #{session_id} #{session_name} #{window_id}' 2>/dev/null
    )
fi

title="${session_name:-Claude Code}"

is_focused && exit 0

note_id=$(( 0x$(printf '%s' "${TMUX_PANE:-no-tmux}" | sha1sum | cut -c1-7) ))

(
    while sleep 1; do
        if is_focused; then
            dunstify -C "$note_id" >/dev/null 2>&1
            exit 0
        fi
    done
) &
watcher_pid=$!
trap 'kill "$watcher_pid" 2>/dev/null' EXIT

action=$(dunstify -t 0 -r "$note_id" -A "default,Switch to Claude" \
    -i utilities-terminal -u normal \
    "$title" "$body")

if [[ "$action" == "default" && -n "$session_id" && -n "$window_id" ]]; then
    tmux switch-client -t "$session_id" 2>/dev/null
    tmux select-window -t "$window_id" 2>/dev/null
    command -v hyprctl >/dev/null 2>&1 && \
        hyprctl dispatch focuswindow "class:$terminal_class" >/dev/null 2>&1
fi
